---
import Layout from '../layouts/Layout.astro';
import { books } from '../data/books.js';
import Header from '../components/Header.astro';

const availableBooks = books; 
---

<Layout 
    title="Lectores Beta | Paulina Lopez" 
    description="Únete a nuestro equipo de lectores beta. Lee antes que nadie y ayuda a dar forma a las próximas historias."
>

<Header /> <div class="fixed inset-0 bg-midnight z-[-1]"></div>
    <main class="min-h-screen flex items-center justify-center relative px-4 py-20 font-lato overflow-hidden pt-28">
        
        <div class="absolute inset-0 bg-midnight z-0"></div>
        <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#A80000] via-transparent to-transparent z-0"></div>
        
        <section class="relative z-10 w-full max-w-xl bg-[#0a0a12]/95 backdrop-blur-xl border border-gray-800 p-8 md:p-12 rounded-2xl shadow-2xl animate-fade-in-up">
            
            <div id="form-header" class="text-center mb-10 transition-opacity duration-500">
                <span class="inline-block py-1 px-4 rounded-full bg-[#A80000]/10 border border-[#A80000]/30 text-[#A80000] font-bold tracking-widest uppercase text-xs mb-6">
                    Acceso Exclusivo
                </span>
                <h1 class="text-3xl md:text-4xl font-cinzel font-bold text-white mb-4 leading-tight">Forma parte de nuestros Lectores Beta</h1>
                <p class="text-gray-400 text-base font-lato leading-relaxed">
                    Sé de los primeros en adentrarte en nuevas historias. Ayuda a dar forma a los manuscritos antes de su publicación.
                </p>
            </div>

            <form id="beta-form" class="space-y-6 transition-all duration-500 font-lato" action="https://marketing.paulinalopezescritora.com/form/submit?formId=2" method="POST">
                
                <input type="hidden" name="mauticform[formId]" value="2" />
                <input type="hidden" name="mauticform[return]" value="" />
                <input type="hidden" name="mauticform[formName]" value="lectoresbeta" />

                <div class="group flex flex-col gap-2 relative">
                    <label class="block text-sm font-bold text-gray-300 transition-colors ml-1" id="label-libro">
                        ¿Qué historia deseas leer primero?
                    </label>
                    
                    <input type="hidden" id="real_libro_preferido" name="mauticform[libro_preferido]" required />

                    <button 
                        type="button" 
                        id="custom-dropdown-btn"
                        class="relative w-full h-14 bg-gray-900 border border-gray-700 text-left rounded-xl pl-12 pr-12 outline-none focus:border-[#A80000] focus:ring-1 focus:ring-[#A80000] hover:bg-gray-800 transition-all shadow-inner"
                    >
                        <div class="absolute left-4 inset-y-0 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        </div>
                        
                        <span id="custom-dropdown-text" class="text-gray-500 text-base font-lato block truncate">Selecciona un libro...</span>
                        
                        <div class="absolute right-4 inset-y-0 flex items-center pointer-events-none text-gray-400 transition-transform duration-300" id="custom-dropdown-icon">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </div>
                    </button>

                    <div id="custom-dropdown-menu" class="hidden absolute z-50 top-[84px] left-0 w-full bg-gray-900 border border-gray-700 rounded-xl shadow-2xl max-h-60 overflow-y-auto opacity-0 translate-y-[-10px] transition-all duration-300">
                        <ul class="py-2 text-base text-gray-300">
                            {availableBooks.map((book) => (
                                <li>
                                    <button 
                                        type="button" 
                                        data-value={book.title} 
                                        class="dropdown-option w-full text-left px-5 py-3 hover:bg-[#A80000] hover:text-white transition-colors flex flex-col"
                                    >
                                        <span class="font-bold">{book.title}</span>
                                        <span class="text-xs text-gray-400 group-hover:text-gray-200 uppercase tracking-wide">{book.category}</span>
                                    </button>
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>

                <div class="group flex flex-col gap-2">
                    <label for="email" class="block text-sm font-bold text-gray-300 group-focus-within:text-[#A80000] transition-colors ml-1">
                        Tu mejor correo electrónico
                    </label>
                    <div class="relative flex items-center">
                        <div class="absolute left-4 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-gray-500 group-focus-within:text-[#A80000] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        </div>
                        
                        <input 
                            type="email" 
                            id="email" 
                            name="mauticform[email]" 
                            required
                            placeholder="lectora@magica.com"
                            class="w-full h-14 bg-gray-900 border border-gray-700 text-white font-lato text-base rounded-xl pl-12 pr-4 outline-none focus:border-[#A80000] focus:ring-1 focus:ring-[#A80000] hover:bg-gray-800 transition-all shadow-inner placeholder-gray-500"
                        />
                    </div>
                </div>

                <button 
                    type="submit" 
                    id="submit-btn"
                    class="w-full h-14 mt-4 bg-[#A80000] hover:bg-red-700 text-white font-bold font-lato text-lg rounded-xl transition-all duration-300 shadow-[0_4px_15px_rgba(168,0,0,0.3)] hover:shadow-[0_6px_20px_rgba(168,0,0,0.5)] hover:-translate-y-0.5 flex justify-center items-center gap-2 group/btn"
                >
                    <span id="btn-text" class="tracking-wide">Solicitar Acceso</span>
                    <svg id="btn-icon" class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    <svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                </button>
            </form>

            <div id="success-state" class="hidden flex-col items-center justify-center text-center py-6 animate-fade-in-up">
                <div class="w-20 h-20 bg-green-900/30 border border-green-500/50 rounded-full flex items-center justify-center mb-6 shadow-[0_0_30px_rgba(34,197,94,0.2)]">
                    <svg class="w-10 h-10 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h2 class="text-3xl font-cinzel font-bold text-white mb-3">¡Solicitud Recibida!</h2>
                <p class="text-gray-400 text-lg font-lato">
                    Has sido añadida a la lista de espera oficial. Mantente atenta a tu bandeja de entrada.
                </p>
                <button onclick="window.location.reload()" class="mt-8 text-sm font-lato text-gray-500 hover:text-white transition-colors underline decoration-gray-600 underline-offset-4">
                    Volver a enviar
                </button>
            </div>
        </section>
    </main>
</Layout>

<style is:global>
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
        animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    /* Estilo del scrollbar dentro del dropdown */
    #custom-dropdown-menu::-webkit-scrollbar {
        width: 8px;
    }
    #custom-dropdown-menu::-webkit-scrollbar-track {
        background: #111827; /* gray-900 */
        border-radius: 8px;
    }
    #custom-dropdown-menu::-webkit-scrollbar-thumb {
        background: #374151; /* gray-700 */
        border-radius: 8px;
    }
    #custom-dropdown-menu::-webkit-scrollbar-thumb:hover {
        background: #A80000;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- LÓGICA DEL CUSTOM DROPDOWN ---
        const dropdownBtn = document.getElementById('custom-dropdown-btn') as HTMLButtonElement;
        const dropdownMenu = document.getElementById('custom-dropdown-menu') as HTMLDivElement;
        const dropdownText = document.getElementById('custom-dropdown-text') as HTMLSpanElement;
        const dropdownIcon = document.getElementById('custom-dropdown-icon') as HTMLDivElement;
        const realInput = document.getElementById('real_libro_preferido') as HTMLInputElement;
        const options = document.querySelectorAll('.dropdown-option');

        // Abrir/Cerrar menú
        if (dropdownBtn && dropdownMenu) {
            dropdownBtn.addEventListener('click', () => {
                const isHidden = dropdownMenu.classList.contains('hidden');
                
                if (isHidden) {
                    dropdownMenu.classList.remove('hidden');
                    // Pequeño timeout para que la transición CSS surta efecto
                    setTimeout(() => {
                        dropdownMenu.classList.remove('opacity-0', 'translate-y-[-10px]');
                        dropdownMenu.classList.add('opacity-100', 'translate-y-0');
                        dropdownIcon.classList.add('rotate-180');
                        dropdownBtn.classList.add('border-[#A80000]', 'ring-1', 'ring-[#A80000]');
                    }, 10);
                } else {
                    closeDropdown();
                }
            });
        }

        // Seleccionar opción
        options.forEach(option => {
            option.addEventListener('click', (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const value = target.getAttribute('data-value');
                
                // Extraer solo el título (sin la categoría) para mostrarlo
                const title = target.querySelector('span:first-child')?.textContent || value;

                if (value && title) {
                    realInput.value = value;
                    dropdownText.textContent = title;
                    dropdownText.classList.remove('text-gray-500');
                    dropdownText.classList.add('text-white');
                    
                    // Disparar evento para que el formulario sepa que el input cambió (por si hay validaciones)
                    realInput.dispatchEvent(new Event('change'));
                }
                closeDropdown();
            });
        });

        // Cerrar al hacer click afuera
        document.addEventListener('click', (e) => {
            const target = e.target as HTMLElement;
            if (dropdownBtn && dropdownMenu && !dropdownBtn.contains(target) && !dropdownMenu.contains(target)) {
                closeDropdown();
            }
        });

        function closeDropdown() {
            if (!dropdownMenu) return;
            dropdownMenu.classList.remove('opacity-100', 'translate-y-0');
            dropdownMenu.classList.add('opacity-0', 'translate-y-[-10px]');
            dropdownIcon?.classList.remove('rotate-180');
            dropdownBtn?.classList.remove('border-[#A80000]', 'ring-1', 'ring-[#A80000]');
            
            setTimeout(() => {
                dropdownMenu.classList.add('hidden');
            }, 300); // Esperar a que termine la animación
        }


        // --- LÓGICA DE ENVÍO A MAUTIC ---
        const form = document.getElementById('beta-form') as HTMLFormElement | null;
        const formHeader = document.getElementById('form-header');
        const successState = document.getElementById('success-state');
        
        if(form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                // Validación extra para asegurar que se seleccionó un libro
                if (!realInput.value) {
                    alert("Por favor, selecciona qué historia deseas leer primero.");
                    // Animación de error (shake) al botón del dropdown
                    dropdownBtn.classList.add('border-red-500', 'animate-pulse');
                    setTimeout(() => dropdownBtn.classList.remove('border-red-500', 'animate-pulse'), 2000);
                    return;
                }
                
                const formData = new FormData(form);
                const actionUrl = form.getAttribute('action');

                if (!actionUrl || actionUrl.includes('[TU_URL_DE_MAUTIC]')) {
                    alert("Aún no has configurado la URL de Mautic en el action del formulario.");
                    return;
                }

                const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
                const btnText = document.getElementById('btn-text');
                const btnIcon = document.getElementById('btn-icon');
                const btnSpinner = document.getElementById('btn-spinner');

                try {
                    if (btn && btnText && btnIcon && btnSpinner) {
                        btnText.textContent = 'Procesando...';
                        btnIcon.classList.add('hidden');
                        btnSpinner.classList.remove('hidden');
                        btn.disabled = true;
                        btn.classList.add('opacity-80', 'cursor-not-allowed');
                    }

                    await fetch(actionUrl, {
                        method: 'POST',
                        body: formData,
                        mode: 'no-cors' 
                    });

                    if (formHeader) formHeader.style.opacity = '0';
                    form.style.opacity = '0';
                    
                    setTimeout(() => {
                        if (formHeader) formHeader.classList.add('hidden');
                        form.classList.add('hidden');
                        if (successState) {
                            successState.classList.remove('hidden');
                            successState.classList.add('flex');
                        } 
                    }, 300);

                } catch (error) {
                    console.error('Error al enviar:', error);
                    alert('Hubo un problema de red. Por favor, revisa tu conexión e inténtalo de nuevo.');
                    
                    if (btn && btnText && btnIcon && btnSpinner) {
                        btnText.textContent = 'Solicitar Acceso';
                        btnSpinner.classList.add('hidden');
                        btnIcon.classList.remove('hidden');
                        btn.disabled = false;
                        btn.classList.remove('opacity-80', 'cursor-not-allowed');
                    }
                }
            });
        }
    });
</script>