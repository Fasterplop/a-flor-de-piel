---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';



const sliderDocs = [
    { id: 'eric', titulo: 'Capítulo de Eric', desc: 'Capítulo extra desde la perspectiva de Eric.', archivo: '/downloads/extra-eric.pdf' },
    { id: 'doc1', titulo: 'Tipos de talentos y naturalezas', desc: 'Guía esencial para identificar las habilidades innatas y la esencia de cada una.', archivo: '/downloads/doc1.pdf' },
    { id: 'doc2', titulo: 'Índice de pócimas', desc: 'Catálogo detallado con las funcionalidades y efectos.', archivo: '/downloads/doc2.pdf' },
    { id: 'doc3', titulo: 'Reglamento de Telepatía', desc: 'Normas éticas y límites legales para la comunicación mental y la intrusión en la mente ajena.', archivo: '/downloads/doc3.pdf' },
    { id: 'doc4', titulo: 'Reglas de combate en Pócimas', desc: 'Protocolo oficial y restricciones para el uso de pócimas en duelos o batallas.', archivo: '/downloads/doc4.pdf' },
    { id: 'doc5', titulo: 'Reglamento de un hayasher', desc: 'Código de conducta, deberes y derechos que rigen a los hayashers.', archivo: '/downloads/doc5.pdf' },
    { id: 'doc6', titulo: 'Reglamento de tutores y guías', desc: 'Directrices para los mentores encargados de la enseñanza, protección y orientación de los nuevos integrantes.', archivo: '/downloads/doc6.pdf' },
    { id: 'doc7', titulo: 'Reglamento de aprendices', desc: 'Obligaciones, prohibiciones y pasos a seguir para los estudiantes en formación.', archivo: '/downloads/doc7.pdf' }
];

---

<Layout 
    title="Recursos Exclusivos | Paulina Lopez" 
    description="Descubre capítulos extras, fondos de pantalla y tests interactivos de la saga A Flor de Piel y otros libros."
>
    <Header /> 
    <div class="fixed inset-0 bg-[#08090B] z-[-1]"></div>
    
    <div id="fireflies-container" class="fixed inset-0 pointer-events-none z-0 overflow-hidden"></div>

    <main class="container pt-40 mx-auto px-4 py-16 max-w-[1400px] font-body relative z-10">
        
        <header class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-gothic font-bold text-[#A80000] mb-4 drop-shadow-md">Recursos Exclusivos</h1>
            <p class="text-gray-300 text-lg max-w-2xl mx-auto drop-shadow-sm font-body">Explora el universo más allá de las páginas. Aquí encontrarás contenido adicional, curiosidades inéditas, material descargable y dinámicas interactivas iluminadas por la magia del bosque.</p>
        </header>

        <section class="mb-20 backdrop-blur-sm bg-midnight/60 p-8 rounded-2xl border border-gray-800 shadow-2xl">
            <div class="flex justify-between items-end mb-8 border-b border-gray-800 pb-3">
                <h2 class="text-3xl font-gothic text-paper">Capítulos Extras y Relatos</h2>
                <div class="flex gap-3 mb-1">
                    <button id="slider-prev" aria-label="Anterior" class="p-2 bg-gray-900 rounded-full border border-gray-700 hover:border-blood text-paper transition-all hover:scale-110">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                    </button>
                    <button id="slider-next" aria-label="Siguiente" class="p-2 bg-gray-900 rounded-full border border-gray-700 hover:border-blood text-paper transition-all hover:scale-110">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
            </div>

            <div id="docs-slider" class="flex gap-6 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-4 scroll-smooth">
                {sliderDocs.map((doc) => (
                    <div class="min-w-[280px] md:min-w-[320px] snap-start shrink-0 bg-midnight p-6 rounded-xl border border-gray-800 hover:border-blood transition-colors duration-300 relative overflow-hidden group flex flex-col justify-between h-auto">
                        <div class="absolute inset-0 bg-gradient-to-br from-blood/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <div class="mb-6">
                            <h3 class="text-xl font-bold mb-2 text-paper relative z-10 font-body">{doc.titulo}</h3>
                            <p class="text-gray-400 text-sm relative z-10 font-body">{doc.desc}</p>
                        </div>
                        <a href={doc.archivo} download class="text-blood font-bold hover:text-red-500 transition-colors inline-flex items-center gap-2 relative z-10 mt-auto">
                            <span>Descargar PDF</span>
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                        </a>
                    </div>
                ))}
            </div>
        </section>

        <section class="mb-20">
            <h2 class="text-3xl font-gothic text-[#E0D6C8] mb-8 border-b border-gray-800 pb-3 inline-block">Fondos de Pantalla</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                {Array.from({ length: 4 }).map((_, i) => (
                    <div class="group relative aspect-video bg-gray-900 rounded-xl overflow-hidden border border-gray-800 shadow-xl transform-gpu">
                        <img src={`/images/wallpapers/banner%20${i + 1}.png`} alt={`Fondo de Pantalla ${i + 1}`} class="object-cover w-full h-full opacity-70 group-hover:opacity-100 transition-all duration-500 group-hover:scale-110" loading="lazy" />
                        <div class="absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <a href={`/images/wallpapers/banner%20${i + 1}.png`} download={`Fondo-A-Flor-De-Piel-${i + 1}.png`} class="bg-[#A80000] text-[#E0D6C8] px-6 py-2 rounded-lg font-bold font-body text-sm tracking-wide shadow-lg hover:bg-red-800 hover:scale-105 transition-all border border-red-900">Descargar</a>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <section class="mb-20 relative">
            <h2 class="text-3xl font-gothic text-[#E0D6C8] mb-8 border-b border-gray-800 pb-3 inline-block">Tests Interactivos</h2>
            <p class="text-gray-300 font-body mb-8 max-w-3xl drop-shadow-sm">Descubre tu rol en el universo de las historias. Selecciona el test que deseas realizar:</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 relative z-10">
                
                <div class="bg-gradient-to-br from-[#0a0a0a]/95 to-[#08090B]/95 p-8 rounded-xl border border-gray-700 flex flex-col h-full shadow-2xl hover:border-[#D4AF37]/50 hover:shadow-[0_0_20px_rgba(212,175,55,0.15)] transition-all duration-300 group transform-gpu">
                    <div class="mb-4">
                        <span class="text-[10px] font-bold tracking-widest text-[#A80000] uppercase font-body">A Flor de Piel</span>
                        <h3 class="text-xl xl:text-2xl font-bold font-gothic text-[#E0D6C8] mt-1 group-hover:text-[#D4AF37] transition-colors leading-tight">Test del Castillo Hayashi</h3>
                    </div>
                    <p class="text-gray-400 text-sm font-body mb-8 flex-grow">Descubre qué rol desempeñarías dentro de los muros del Castillo Hayashi. ¿Serías guía, aprendiz o guardia?</p>
                    <a href="/libros/a-flor-de-piel/#quiz" class="block w-full text-center bg-[#A80000] hover:bg-red-800 text-[#E0D6C8] font-bold font-body py-3 px-4 rounded-lg transition-all duration-300 shadow-[0_0_15px_rgba(168,0,0,0.4)] hover:shadow-[0_0_25px_rgba(168,0,0,0.6)] text-sm">Ir al Quiz</a>
                </div>

                <div class="bg-gradient-to-br from-[#0a0a0a]/95 to-[#08090B]/95 p-8 rounded-xl border border-gray-700 flex flex-col h-full shadow-2xl hover:border-[#D4AF37]/50 hover:shadow-[0_0_20px_rgba(212,175,55,0.15)] transition-all duration-300 group transform-gpu">
                    <div class="mb-4">
                        <span class="text-[10px] font-bold tracking-widest text-[#A80000] uppercase font-body">A Pulso Lento</span>
                        <h3 class="text-xl xl:text-2xl font-bold font-gothic text-[#E0D6C8] mt-1 group-hover:text-[#D4AF37] transition-colors leading-tight">Nivel de Supervivencia</h3>
                    </div>
                    <p class="text-gray-400 text-sm font-body mb-8 flex-grow">Averigua si tendrías lo necesario para sobrevivir y adaptarte a las crudas realidades de este nuevo entorno.</p>
                    <a href="/libros/a-pulso-lento/#quiz" class="block w-full text-center bg-[#A80000] hover:bg-red-800 text-[#E0D6C8] font-bold font-body py-3 px-4 rounded-lg transition-all duration-300 shadow-[0_0_15px_rgba(168,0,0,0.4)] hover:shadow-[0_0_25px_rgba(168,0,0,0.6)] text-sm">Ir al Quiz</a>
                </div>

                <div class="bg-gradient-to-br from-[#0a0a0a]/95 to-[#08090B]/95 p-8 rounded-xl border border-gray-700 flex flex-col h-full shadow-2xl hover:border-[#D4AF37]/50 hover:shadow-[0_0_20px_rgba(212,175,55,0.15)] transition-all duration-300 group transform-gpu">
                    <div class="mb-4">
                        <span class="text-[10px] font-bold tracking-widest text-[#A80000] uppercase font-body">A Corazón Abierto</span>
                        <h3 class="text-xl xl:text-2xl font-bold font-gothic text-[#E0D6C8] mt-1 group-hover:text-[#D4AF37] transition-colors leading-tight">Test de Estrategia</h3>
                    </div>
                    <p class="text-gray-400 text-sm font-body mb-8 flex-grow">Descubre si tus decisiones te llevarían a la victoria o al desastre en medio del conflicto bélico.</p>
                    <a href="/libros/a-corazon-abierto/#quiz" class="block w-full text-center bg-[#A80000] hover:bg-red-800 text-[#E0D6C8] font-bold font-body py-3 px-4 rounded-lg transition-all duration-300 shadow-[0_0_15px_rgba(168,0,0,0.4)] hover:shadow-[0_0_25px_rgba(168,0,0,0.6)] text-sm">Ir al Quiz</a>
                </div>

                <div class="bg-gradient-to-br from-[#0a0a0a]/95 to-[#08090B]/95 p-8 rounded-xl border border-gray-700 flex flex-col h-full shadow-2xl hover:border-[#D4AF37]/50 hover:shadow-[0_0_20px_rgba(212,175,55,0.15)] transition-all duration-300 group transform-gpu">
                    <div class="mb-4">
                        <span class="text-[10px] font-bold tracking-widest text-[#A80000] uppercase font-body">Primero yo, Segundo yo, Tercero yo</span>
                        <h3 class="text-xl xl:text-2xl font-bold font-gothic text-[#E0D6C8] mt-1 group-hover:text-[#D4AF37] transition-colors leading-tight">Test de Prioridades</h3>
                    </div>
                    <p class="text-gray-400 text-sm font-body mb-8 flex-grow">Descubre qué tanto te priorizas a ti misma en diferentes situaciones de la vida diaria y aprende a ponerte en primer lugar.</p>
                    <a href="/libros/primero-yo-segundo-yo-tercero-yo/#quiz" class="block w-full text-center bg-[#A80000] hover:bg-red-800 text-[#E0D6C8] font-bold font-body py-3 px-4 rounded-lg transition-all duration-300 shadow-[0_0_15px_rgba(168,0,0,0.4)] hover:shadow-[0_0_25px_rgba(168,0,0,0.6)] text-sm">Ir al Quiz</a>
                </div>

            </div>
        </section>

        <section class="mb-20">
            <h2 class="text-3xl font-gothic text-[#E0D6C8] mb-8 border-b border-gray-800 pb-3 inline-block">Curiosidades de los Libros</h2>
            <div class="space-y-4">
                
                <details class="group bg-[#0a0a0a]/95 border border-gray-800 rounded-xl overflow-hidden shadow-lg transform-gpu">
                    <summary class="flex justify-between items-center font-gothic text-2xl font-bold cursor-pointer list-none p-6 text-[#E0D6C8] hover:text-[#D4AF37] transition-colors bg-gradient-to-r hover:from-gray-900/50 hover:to-transparent">
                        <span>A Flor de Piel</span>
                        <span class="transition group-open:rotate-180 text-[#A80000]">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="p-6 pt-2 border-t border-gray-800/50 bg-[#050505]">
                        <ul class="space-y-4 text-gray-300 font-body leading-relaxed custom-bullets">
                            <li>Entre la lista de nombres para Nina estaban Soledad, Nube, y un par más que no recuerdo. Sí, ya sé que son malísimos.</li>
                            <li>La historia nació de un sueño donde Nina estaba montada en una mesa a punto de lanzar la pócima que paraliza el tiempo para salvar a alguien.</li>
                            <li>Akami es el personaje que más se parece a mí por su personalidad.</li>
                            <li>El nombre de Liang en realidad es el nombre de un comercio que quedaba frente a mi casa.</li>
                            <li>Comencé a escribir la historia a los 17, la terminé en el 2018, pero solo hasta el 2026 conseguí una versión con la que estuviera conforme, después de haber editado 10000000 veces, y haber incluido las correcciones de mis lectoras beta.</li>
                            <li>Tuve que dividir el libro en dos porque era demasiado largo, así que se puede decir que <i>A pulso lento</i> es la parte 2 de <i>A flor de piel</i>.</li>
                            <li>A flor de piel fue pensado para ser una trilogía, pero luego de haber escrito el tercer libro en el 2019, llegué a la conclusión de que será una saga.</li>
                            <li>Nada de la historia fue planeado, ya que soy escritora brújula.</li>
                            <li>La mayoría de los capítulos fueron escritos mientras escuchaba a Avril Lavigne.</li>
                            <li>Los primeros 4 capítulos fueron escritos en un cuaderno.</li>
                        </ul>
                    </div>
                </details>

                <details class="group bg-[#0a0a0a]/95 border border-gray-800 rounded-xl overflow-hidden shadow-lg transform-gpu">
                    <summary class="flex justify-between items-center font-gothic text-2xl font-bold cursor-pointer list-none p-6 text-[#E0D6C8] hover:text-[#D4AF37] transition-colors bg-gradient-to-r hover:from-gray-900/50 hover:to-transparent">
                        <span>A Pulso Lento</span>
                        <span class="transition group-open:rotate-180 text-[#A80000]">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="p-6 pt-2 border-t border-gray-800/50 bg-[#050505]">
                        <ul class="space-y-4 text-gray-300 font-body leading-relaxed custom-bullets">
                            <li>El edificio Hayashi está inspirado en una construcción que estaba abandonada frente a mi parada de autobús.</li>
                            <li>Las grullas se originaron a raíz de mi reto personal de hacer 1000 grullas para que se cumpla un deseo.</li>
                            <li>Los DAMA'S fueron creados para desarrollar a los personajes en sus peores momentos.</li>
                            <li>Megan tiene su historia alternativa, que se desarrolla entre el 3er y 4to libro. Es una de las historias más crudas que me ha tocado escribir.</li>
                        </ul>
                    </div>
                </details>

                <details class="group bg-[#0a0a0a]/95 border border-gray-800 rounded-xl overflow-hidden shadow-lg transform-gpu">
                    <summary class="flex justify-between items-center font-gothic text-2xl font-bold cursor-pointer list-none p-6 text-[#E0D6C8] hover:text-[#D4AF37] transition-colors bg-gradient-to-r hover:from-gray-900/50 hover:to-transparent">
                        <span>A Corazón Abierto</span>
                        <span class="transition group-open:rotate-180 text-[#A80000]">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="p-6 pt-2 border-t border-gray-800/50 bg-[#050505]">
                        <ul class="space-y-4 text-gray-300 font-body leading-relaxed custom-bullets">
                            <li>Estudié sobre la terminología militar y la primera y segunda guerra mundial para entender muchas de las situaciones que quería implementar en el libro, pero no sabía cómo. Luego de eso me alejé muchísimo de las películas bélicas porque había absorbido cierta parte de la energía y sufrimiento de aquella época, generándome cansancio.</li>
                            <li>El final estaba pautado para ser el inicio del 4to libro, pero quise adelantarlo para que fuese más sorprendente, y no dejarlo tan abierto, como acostumbro a hacer.</li>
                        </ul>
                    </div>
                </details>

            </div>
        </section>

    </main>

</Layout>

<style is:global>
    /* Estilos optimizados de las luciérnagas doradas con aceleración de hardware */
    .firefly {
        position: absolute;
        width: 3px;
        height: 3px;
        background-color: #C5A059; 
        border-radius: 50%;
        box-shadow: 0 0 6px 1px #C5A059, 0 0 12px 3px rgba(197, 160, 89, 0.8);
        opacity: 0;
        pointer-events: none;
        will-change: transform, opacity;
    }

    @keyframes float {
        0% { transform: translate3d(0, 0, 0); }
        25% { transform: translate3d(20px, -30px, 0); }
        50% { transform: translate3d(-15px, -60px, 0); }
        75% { transform: translate3d(10px, -20px, 0); }
        100% { transform: translate3d(0, 0, 0); }
    }

    @keyframes blink {
        0%, 100% { opacity: 0; }
        50% { opacity: 0.9; }
    }

    /* Viñetas personalizadas para las curiosidades */
    .custom-bullets li {
        position: relative;
        padding-left: 1.5rem;
    }
    .custom-bullets li::before {
        content: "✦";
        position: absolute;
        left: 0;
        color: #D4AF37;
        font-size: 1.2rem;
        line-height: 1;
        top: 0.1rem;
    }

    details > summary { list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const container = document.getElementById('fireflies-container');
        if (!container) return;
        
        const firefliesCount = 30; 
        
        const fragment = document.createDocumentFragment();
        
        for (let i = 0; i < firefliesCount; i++) {
            const firefly = document.createElement('div');
            firefly.classList.add('firefly');
            
            firefly.style.left = `${Math.random() * 100}%`;
            firefly.style.top = `${Math.random() * 100}%`;
            
            const floatDuration = 15 + Math.random() * 20;
            const blinkDuration = 3 + Math.random() * 5;  
            const delay = Math.random() * 10;             
            
            firefly.style.animation = `
                float ${floatDuration}s infinite ease-in-out ${delay}s,
                blink ${blinkDuration}s infinite ease-in-out ${delay}s
            `;
            
            fragment.appendChild(firefly);
        }
        
        container.appendChild(fragment);
    });

   // Lógica del Slider de Documentos
const slider = document.getElementById('docs-slider');
const btnPrev = document.getElementById('slider-prev');
const btnNext = document.getElementById('slider-next');

if (btnPrev && btnNext && slider) {
    btnPrev.addEventListener('click', () => {
        const firstCard = slider.firstElementChild;
        if (firstCard) {
            const scrollAmount = firstCard.clientWidth + 24; // 24 es el gap de Tailwind (gap-6)
            slider.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        }
    });

    btnNext.addEventListener('click', () => {
        const firstCard = slider.firstElementChild;
        if (firstCard) {
            const scrollAmount = firstCard.clientWidth + 24;
            slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        }
    });
}
</script>